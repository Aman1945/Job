# Server Configuration
PORT=3000
NODE_ENV=production

# Database
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/nexusoms?retryWrites=true&w=majority

# JWT Authentication
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long
JWT_EXPIRY=7d

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key-here

# Google Maps (for Logistics Cost Calculator)
GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=500

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# DigitalOcean Spaces (S3-compatible Object Storage)
DO_SPACES_KEY=your-spaces-access-key-id
DO_SPACES_SECRET=your-spaces-secret-access-key
DO_SPACES_REGION=sgp1
DO_SPACES_BUCKET=bigsams-oms-prod
DO_SPACES_CDN_URL=https://bigsams-oms-prod.sgp1.cdn.digitaloceanspaces.com
